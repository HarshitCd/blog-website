        </section>
        <section class="more-info">
            <a href="/contact">
                <button class="contact-me">Reach Out</button>
            </a>
            <a
                href="/Harshit_Chelladurai_Resume.pdf"
                target="_blank"
                rel="noopener noreferrer"
                download
            >
                <button class="resume">Resume</button>
            </a>
        </section>
    </div>
    <Image src={DP} alt="me" class="about-pic" />

    <style>
        h2 {
            font-size: 5rem;
        }

        .header-line {
            border-top: solid 6px #2e2e2e;
            margin-bottom: 2.5rem;
            width: 25%;
        }

        .about {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8rem;
        }

        .about-content p {
            font-size: 1.05rem;
        }

        .about-pic {
            border: solid 1px #bebebe;
            border-radius: 20%;
            width: 25rem;
            height: auto;
            transform: scaleX(-1);
        }

        .more-info {
            margin-top: 2.5rem;
            display: flex;

            gap: 1rem;
        }

        a {
            text-decoration: none;
        }

        button {
            background-color: #ececec;
            border: solid 1px #bebebe;
            border-radius: 3px;

            padding: 1rem;

            cursor: pointer;

            font-size: 1rem;
            font-weight: 500;
        }

        button:hover {
            background-color: #dcdcdc;
        }
    </style>
</section>
