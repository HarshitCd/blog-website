---
import { Image } from "astro:assets";
import DP from "../assets/dp.jpeg";
import LI from "../assets/linkedin_icon.svg";
import GM from "../assets/gmail_icon.svg";
import GH from "../assets/github_icon.svg";
---

<h2>About</h2>
<div class="header-line"></div>

<section class="about">
    <div class="about-content">
        <section>
            <p>
                I’m a backend engineer in Bengaluru who works mainly with Python
                and Go, and also with Java. I build reliable systems like VM
                placement, host observability, and log aggregation tools. I
                focus on performance, fewer bugs, and clear documentation. I
                write clean, maintainable code, automate testing and
                deployments, and support tools that run on thousands of hosts.
            </p>
            <br />
            <p>
                I enjoy building small projects that solve real problems
                automation scripts, developer tools, and security utilities. I
                like moving ideas from prototype to production, learning new
                tools as needed, and keeping projects simple and well documented
                so others can use and extend them.
            </p>
        </section>
        <section class="more-info">
            <!-- <a href="/about">
                <button class="contact-me">Reach Out</button>
            </a> -->
            <a
                href="https://linkedin.com/in/harshit-chelladurai"
                target="_blank"
                class="linkedin"
            >
                <button>
                    <Image src={LI} alt="LinkedIn" width={24} height={24} />
                </button>
            </a>
            <a
                href="https://github.com/HarshitCd"
                target="_blank"
                class="github"
            >
                <button>
                    <Image src={GH} alt="Github" width={24} height={24} />
                </button>
            </a>
            <a
                href="mailto:harshitchelladurai@gmail.com"
                target="_blank"
                class="email"
            >
                <button>
                    <Image src={GM} alt="Gmail" width={24} height={24} />
                </button>
            </a>
            <a
                href="/Harshit_Chelladurai_Resume.pdf"
                target="_blank"
                rel="noopener noreferrer"
                download
            >
                <button class="resume">Resume</button>
            </a>
        </section>
    </div>
    <Image src={DP} alt="me" class="about-pic" />
</section>

<style>
    h2 {
        font-size: 2rem;
        font-weight: 500;
    }

    .header-line {
        border-top: solid 1px #bebebe;
        margin-bottom: 2.5rem;
        width: 100%;
    }

    .about {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;

        gap: 2rem;

        margin-bottom: 2.5rem;
    }

    .about-content p {
        font-size: 0.9rem;
    }

    .about-pic {
        border: solid 1px #bebebe;
        border-radius: 20px;

        max-width: 85vw;
        width: 25rem;
        height: auto;

        transform: scaleX(-1);
        order: -1;
    }

    .more-info {
        margin-top: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;

        gap: 1.25rem;
    }

    a {
        text-decoration: none;
    }

    .more-info button {
        display: flex;
        align-items: center;

        background-color: #ececec;
        border: solid 1px #bebebe;
        border-radius: 3px;

        padding: 1rem;
        height: 4rem;

        cursor: pointer;

        font-size: 1rem;
        font-weight: 500;
    }

    button:hover {
        background-color: #dcdcdc;
    }

    @media (min-width: 720px) {
        h2 {
            font-size: 4rem;
        }

        .about {
            flex-direction: row;
        }

        .about-content p {
            font-size: 1rem;
        }

        .about-pic {
            order: 0;
        }
    }
</style>
